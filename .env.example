# =============================================================================
# 环境变量配置
# 将以下内容复制为 .env 并填入实际值
# =============================================================================

# === LLM API 配置（必需） ===
# 用于 arxiv-daily-researcher 的论文评分和深度分析
# CHEAP_LLM 用于评分（建议用低成本模型）
# SMART_LLM 用于深度分析和综述归纳（建议用更强模型）
ARK_API_KEY=ark-your-key-here
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_MODEL_NAME=deepseek-v4-flash
SMART_MODEL_NAME=deepseek-v4-pro

# === GitHub API（可选，本地 upstream awesome 发现提额） ===
# GitHub 不允许用户自定义以 GITHUB_ 开头的 secret/variable 名称，这里统一用 GH_TOKEN。
# GH_TOKEN=github_pat_your-token-here

# === MinerU PDF 解析 API（可选） ===
# 用于从 PDF 中提取论文 Figure 作为 teaser 图
# 申请地址: https://mineru.net/apiManage/apiKey
# MINERU_API_KEY=your-mineru-api-token-here
