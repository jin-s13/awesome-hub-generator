# =============================================================================
# awesome-hub-generator 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入你的 API Key。
# .env 已在 .gitignore 中，不会被提交到代码仓库。
# 在 GitHub Actions 中使用时，请将以下变量配置为 Repository Secrets。
# =============================================================================

# ---- LLM 配置 ----
# 低成本 LLM — 评分、翻译、TLDR、关键词标准化
# 推荐: deepseek-chat, gpt-4o-mini
CHEAP_LLM__API_KEY=sk-your-key-here
CHEAP_LLM__BASE_URL=https://ark.cn-beijing.volces.com/api/v3
CHEAP_LLM__MODEL_NAME=deepseek-v4-flash

# 高性能 LLM — 深度 PDF 全文分析、趋势综合分析
# 推荐: deepseek-v4-flash, gpt-4o, claude-3-opus
SMART_LLM__API_KEY=sk-your-key-here
SMART_LLM__BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SMART_LLM__MODEL_NAME=deepseek-v4-flash

# ---- GitHub 配置（用于自动推送产物到输出仓库）----
# GitHub Personal Access Token，需有输出仓库的写入权限
# 或使用 GitHub Actions 自动提供的 GITHUB_TOKEN
GITHUB_TOKEN=
GITHUB_OUTPUT_REPO=your-username/awesome-cad-hub
