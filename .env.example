# =============================================================================
# 环境变量配置
# 将以下内容复制为 .env 并填入实际值
# =============================================================================

# === LLM API 配置（必需） ===
# 用于 arxiv-daily-researcher 的论文评分和深度分析
# CHEAP_LLM 用于评分（建议用低成本模型）
# SMART_LLM 用于深度分析（建议用更强模型，可选，默认同 CHEAP_LLM）
ARK_API_KEY=sk-your-key-here
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_NAME=deepseek-v4-flash-260425
SMART_MODEL_NAME=deepseek-v4-flash-260425

# === MinerU PDF 解析 API（可选） ===
# 用于从 PDF 中提取论文 Figure 作为 teaser 图
# 申请地址: https://mineru.net/apiManage/apiKey
# MINERU_API_KEY=your-mineru-api-token-here
