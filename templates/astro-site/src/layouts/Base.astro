---
import { t, useTranslations } from '../lib/i18n';
import { getLang, localizePath, alternateLang, type Lang } from '../lib/lang';

const { title = '{{PROJECT_NAME}}', description = '{{PROJECT_DESCRIPTION}}', lang: _lang } = Astro.props;
const lang: Lang = _lang || getLang(Astro.url);
const _t = useTranslations(lang);
const altLang = alternateLang(lang);

const nav = [
  { href: localizePath('/', lang), label: _t('nav.home') },
  { href: localizePath('/papers', lang), label: _t('nav.papers') },
  { href: localizePath('/trends', lang), label: _t('nav.trends') },
  { href: localizePath('/datasets', lang), label: _t('nav.datasets') },
  { href: localizePath('/tools', lang), label: _t('nav.tools') },
];
const githubUrl = '{{GITHUB_URL}}';
const altUrl = localizePath(Astro.url.pathname, altLang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a href={localizePath('/', lang)} class="brand" aria-label="{{PROJECT_NAME}} home">
          <span class="brand-mark">⌁</span>
          <span>
            <strong>{{PROJECT_NAME}}</strong>
            <small>{_t('brand.subtitle')}</small>
          </span>
        </a>
        <nav class="nav">
          {nav.map((item) => (
            <a class:list={[Astro.url.pathname === item.href && 'active']} href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="header-actions">
          <a class="lang-switcher" href={altUrl}>{altLang === 'en' ? 'English' : '中文'}</a>
          <a class="github-link" href={githubUrl} target="_blank" rel="noreferrer">{_t('nav.github')}</a>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        {{FOOTER_HTML}}
      </footer>
    </div>
  </body>
</html>
