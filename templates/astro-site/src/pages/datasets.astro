---
import Base from '../layouts/Base.astro';
import ResourceCard from '../components/ResourceCard.astro';
import FilterBar from '../components/FilterBar.astro';
import { getDatasets, uniq } from '../lib/data';
import { useTranslations } from '../lib/i18n';
import { getLang, type Lang } from '../lib/lang';

const { lang: _lang } = Astro.props;
const lang: Lang = _lang || getLang(Astro.url);
const _t = useTranslations(lang);

const datasets = getDatasets();
const categories = uniq(datasets.map((d) => d.category || 'Dataset')).sort();
const years = uniq(datasets.map((d) => d.year).filter(Boolean) as number[]).sort((a, b) => b - a);
---
<Base title={`${_t('pages.datasets.title')} · {{PROJECT_NAME}}`} lang={lang}>
  <section class="page-title">
    <p class="eyebrow">{_t('pages.datasets.eyebrow')}</p>
    <h1>{_t('pages.datasets.title')}</h1>
    <p>{_t('pages.datasets.description')}</p>
  </section>
  <FilterBar categories={categories} years={years} placeholder={_t('filter.search') + ' by dataset, representation, task, source...'} lang={lang} />
  <div class="card-grid resource-grid">
    {datasets.map((item) => <ResourceCard item={item} lang={lang} />)}
  </div>
</Base>
