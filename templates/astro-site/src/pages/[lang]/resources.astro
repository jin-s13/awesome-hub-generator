---
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getResources, uniq } from '../../lib/data';
import { useTranslations } from '../../lib/i18n';
import { type Lang } from '../../lib/lang';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as Lang;
const _t = useTranslations(lang);

const resources = getResources();
const categories = uniq(resources.map((r) => r.type || r.resource_type || 'Resource')).filter(Boolean).sort();
---
<Base title={`${_t('pages.resources.title')} · {{PROJECT_NAME}}`} lang={lang}>
  <section class="page-title">
    <p class="eyebrow">{_t('pages.resources.eyebrow')}</p>
    <h1>{_t('pages.resources.title')}</h1>
    <p>{_t('pages.resources.description')}</p>
  </section>
  <FilterBar categories={categories} years={[]} placeholder={_t('filter.search') + ' by name, type, tag, source...'} lang={lang} />
  <div class="card-grid resource-grid">
    {resources.map((item) => <ResourceCard item={item} lang={lang} />)}
  </div>
</Base>
