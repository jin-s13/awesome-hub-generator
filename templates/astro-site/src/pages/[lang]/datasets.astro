---
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getDatasets, uniq } from '../../lib/data';
import { useTranslations } from '../../lib/i18n';
import { type Lang } from '../../lib/lang';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as Lang;
const _t = useTranslations(lang);

const datasets = getDatasets();
const years = uniq(datasets.map((d) => d.year).filter(Boolean) as number[]).sort((a, b) => b - a);
---
<Base title={`${_t('pages.datasets.title')} · {{PROJECT_NAME}}`} lang={lang}>
  <section class="page-title">
    <p class="eyebrow">{_t('pages.datasets.eyebrow')}</p>
    <h1>{_t('pages.datasets.title')}</h1>
    <p>{_t('pages.datasets.description')}</p>
  </section>
  <FilterBar years={years} placeholder={_t('filter.search') + ' by dataset, representation, task, source...'} lang={lang} />
  <div class="card-grid resource-grid">
    {datasets.map((item) => <ResourceCard item={item} mode="paper" lang={lang} />)}
  </div>
</Base>
