---
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getProjects, uniq } from '../../lib/data';
import { useTranslations } from '../../lib/i18n';
import { type Lang } from '../../lib/lang';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as Lang;
const _t = useTranslations(lang);

const projects = getProjects();
const categories = uniq(projects.map((item) => item.type || 'GitHub')).sort();
const sortOptions = [
  { value: 'stars', label: _t('filter.sortStars') },
  { value: 'alpha', label: _t('filter.sortAlpha') },
];
---
<Base title={`${_t('pages.projects.title')} · {{PROJECT_NAME}}`} lang={lang}>
  <section class="page-title">
    <p class="eyebrow">{_t('pages.projects.eyebrow')}</p>
    <h1>{_t('pages.projects.title')}</h1>
    <p>{_t('pages.projects.description')}</p>
  </section>
  <FilterBar categories={categories} years={[]} placeholder={_t('filter.search') + ' by project, repo, language, tag...'} sortOptions={sortOptions} lang={lang} />
  <div class="card-grid resource-grid" data-sort-container>
    {projects.map((item) => <ResourceCard item={item} lang={lang} />)}
  </div>
</Base>
