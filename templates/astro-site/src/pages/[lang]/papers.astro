---
import Base from '../../layouts/Base.astro';
import FilterBar from '../../components/FilterBar.astro';
import ProgressivePaperGrid from '../../components/ProgressivePaperGrid.astro';
import { getPapers, paperTypeList, uniq } from '../../lib/data';
import { useTranslations } from '../../lib/i18n';
import { type Lang } from '../../lib/lang';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as Lang;
const _t = useTranslations(lang);

const papers = getPapers();
const categories = uniq(papers.flatMap((p) => paperTypeList(p))).sort();
const years = uniq(papers.map((p) => p.year)).sort((a, b) => b - a);
const sortOptions = [
  { value: 'score', label: _t('filter.sortScore') },
  { value: 'year', label: _t('filter.sortYear') },
  { value: 'alpha', label: _t('filter.sortAlpha') },
];
---
<Base title={`${_t('pages.papers.title')} · {{PROJECT_NAME}}`} lang={lang}>
  <section class="page-title">
    <p class="eyebrow">{_t('pages.papers.eyebrow')}</p>
    <h1>{_t('pages.papers.title')}</h1>
    <p>{_t('pages.papers.description')}</p>
  </section>
  <FilterBar categories={categories} years={years} sortOptions={sortOptions} lang={lang} />
  <ProgressivePaperGrid papers={papers} lang={lang} />
</Base>
