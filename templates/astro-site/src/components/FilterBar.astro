---
import { useTranslations } from '../lib/i18n';
import { type Lang } from '../lib/lang';
type SortOption = { value: string; label: string };
const {
  categories = [],
  years = [],
  placeholder = 'Search by title, tag, venue, representation...',
  sortOptions = [],
  lang: _lang = 'en',
} = Astro.props as {
  categories?: string[];
  years?: number[];
  placeholder?: string;
  sortOptions?: SortOption[];
  lang?: Lang;
};
const lang: Lang = _lang;
const _t = useTranslations(lang);
const resultTemplate = _t('filter.resultCount');
---
<section class="filter-panel" aria-label="Filters">
  <label class="search-box">
    <span>{_t('filter.search')}</span>
    <input id="searchInput" type="search" placeholder={placeholder} />
  </label>
  {categories.length > 0 && (
    <label>
      <span>{_t('filter.category')}</span>
      <select id="categorySelect">
        <option value="">{_t('filter.allCategories')}</option>
        {categories.map((c: string) => <option value={c}>{c}</option>)}
      </select>
    </label>
  )}
  {years.length > 0 && (
    <label>
      <span>{_t('filter.year')}</span>
      <select id="yearSelect">
        <option value="">{_t('filter.allYears')}</option>
        {years.map((y: number) => <option value={String(y)}>{y}</option>)}
      </select>
    </label>
  )}
  {sortOptions.length > 0 && (
    <label>
      <span>{_t('filter.sort')}</span>
      <select id="sortSelect">
        {sortOptions.map((option: SortOption) => <option value={option.value}>{option.label}</option>)}
      </select>
    </label>
  )}
  <button id="resetFilters" type="button">{_t('filter.reset')}</button>
  <p id="resultCount" class="result-count" data-result-template={resultTemplate}></p>
</section>

<script>
  const searchInput = document.getElementById('searchInput');
  const categorySelect = document.getElementById('categorySelect');
  const yearSelect = document.getElementById('yearSelect');
  const sortSelect = document.getElementById('sortSelect');
  const resetButton = document.getElementById('resetFilters');
  const resultCount = document.getElementById('resultCount');
  const items = Array.from(document.querySelectorAll('.filter-item'));
  items.forEach((item, index) => {
    if (!item.dataset.initialIndex) item.dataset.initialIndex = String(index);
  });
  const sortContainer = document.querySelector('[data-sort-container]') || document.querySelector('.card-grid');
  const progressiveGrid = document.querySelector('[data-progressive-grid]');
  const resultTemplate = resultCount?.getAttribute('data-result-template') || '{0} / {1} shown';

  function normalize(value) {
    return String(value || '').trim().toLowerCase();
  }

  function updateResultCount(visible, total) {
    if (resultCount) resultCount.textContent = resultTemplate.replace('{0}', String(visible)).replace('{1}', String(total));
  }

  function numericSortValue(item) {
    const value = Number(item.dataset.score || 0);
    return Number.isFinite(value) ? value : 0;
  }

  function alphaSortValue(item) {
    return normalize(item.dataset.title || item.dataset.search);
  }

  function yearSortValue(item) {
    const value = Number(item.dataset.year || 0);
    return Number.isFinite(value) ? value : 0;
  }

  function sortItems() {
    if (!sortSelect || !sortContainer || progressiveGrid) return;
    const mode = sortSelect.value;
    const sorted = [...items].sort((a, b) => {
      if (mode === 'alpha') {
        return alphaSortValue(a).localeCompare(alphaSortValue(b)) || numericSortValue(b) - numericSortValue(a);
      }
      if (mode === 'score' || mode === 'stars') {
        return numericSortValue(b) - numericSortValue(a) || alphaSortValue(a).localeCompare(alphaSortValue(b));
      }
      if (mode === 'year') {
        return yearSortValue(b) - yearSortValue(a) || numericSortValue(b) - numericSortValue(a) || alphaSortValue(a).localeCompare(alphaSortValue(b));
      }
      return Number(a.dataset.initialIndex || 0) - Number(b.dataset.initialIndex || 0);
    });
    for (const item of sorted) sortContainer.appendChild(item);
  }

  function applyFilters() {
    const q = normalize(searchInput?.value);
    const category = normalize(categorySelect?.value);
    const year = normalize(yearSelect?.value);

    if (progressiveGrid) {
      window.dispatchEvent(new CustomEvent('hub-filter-change', {
        detail: { query: q, category, year, sort: sortSelect?.value || '' },
      }));
      return;
    }

    let visible = 0;

    for (const item of items) {
      const haystack = normalize(item.dataset.search);
      const itemCategories = normalize(item.dataset.category).split('|').filter(Boolean);
      const itemYear = normalize(item.dataset.year);
      const ok = (!q || haystack.includes(q)) && (!category || itemCategories.includes(category)) && (!year || itemYear === year);
      item.toggleAttribute('hidden', !ok);
      if (ok) visible += 1;
    }
    updateResultCount(visible, items.length);
  }

  searchInput?.addEventListener('input', applyFilters);
  categorySelect?.addEventListener('change', applyFilters);
  yearSelect?.addEventListener('change', applyFilters);
  sortSelect?.addEventListener('change', () => {
    sortItems();
    applyFilters();
  });
  window.addEventListener('hub-filter-count', (event) => {
    const detail = event.detail || {};
    updateResultCount(detail.visible ?? 0, detail.total ?? items.length);
  });
  resetButton?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (categorySelect) categorySelect.value = '';
    if (yearSelect) yearSelect.value = '';
    if (sortSelect) sortSelect.selectedIndex = 0;
    sortItems();
    applyFilters();
  });
  sortItems();
  applyFilters();
</script>
