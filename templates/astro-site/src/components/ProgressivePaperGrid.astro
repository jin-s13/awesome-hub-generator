---
import PaperCard from './PaperCard.astro';
import type { Paper } from '../lib/data';
import { paperTypeFilterValue, paperTypeLabel, paperTypeList } from '../lib/data';
import { useTranslations } from '../lib/i18n';
import { assetPath, localizePath, type Lang } from '../lib/lang';

const { papers, lang: _lang = 'en' } = Astro.props as { papers: Paper[]; lang?: Lang };
const lang: Lang = _lang;
const _t = useTranslations(lang);

const INITIAL_VISIBLE_COUNT = 48;
const BATCH_SIZE = 48;

const linkLabelMap: Record<string, { en: string; zh: string }> = {
  paper: { en: 'Paper', zh: '论文' },
  pdf: { en: 'PDF', zh: 'PDF' },
  code: { en: 'Code', zh: '代码' },
  github: { en: 'GitHub', zh: 'GitHub' },
  repo: { en: 'Repo', zh: '仓库' },
  dataset: { en: 'Dataset', zh: '数据集' },
  data: { en: 'Data', zh: '数据' },
  project: { en: 'Project', zh: '项目' },
  demo: { en: 'Demo', zh: '演示' },
};

function linkLabel(key: string) {
  const normalized = key.toLowerCase();
  const known = linkLabelMap[normalized];
  if (known) return known[lang];
  return key
    .replace(/[_-]/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function scoreInfo(paper: Paper) {
  const score = paper.score?.read_first_score ?? paper.score?.total;
  if (score == null) return { score: null, level: null };
  return {
    score,
    level: score >= 80 ? 'high' : score >= 60 ? 'medium' : 'low',
  };
}

function paperSearchText(paper: Paper, typeLabel: string, sourceRepos: string) {
  return [
    paper.title,
    paper.title_cn,
    paper.venue,
    paper.year,
    typeLabel,
    ...paperTypeList(paper),
    ...(paper.tags || []),
    ...(paper.representations || []),
    sourceRepos,
  ].filter(Boolean).join(' ').toLowerCase();
}

const initialPapers = papers.slice(0, INITIAL_VISIBLE_COUNT);
const paperIndex = papers.map((paper, index) => {
  const typeLabel = paperTypeLabel(paper);
  const sourceRepos = (paper.sources || []).map((s) => s.repo).join(', ');
  const score = scoreInfo(paper);
  return {
    id: paper.id,
    index,
    title: paper.title,
    displayTitle: (lang === 'zh' && paper.title_cn) ? paper.title_cn : paper.title,
    venueYear: `${paper.venue} ${paper.year}`,
    year: String(paper.year || ''),
    typeLabel,
    category: paperTypeFilterValue(paper),
    searchText: paperSearchText(paper, typeLabel, sourceRepos),
    detailUrl: localizePath(`/papers/${paper.id}`, lang),
    preview: assetPath(paper.preview || '/assets/placeholder.svg'),
    score: score.score,
    scoreLevel: score.level,
    tldr: (lang === 'zh' && paper.tldr_cn) ? paper.tldr_cn : (paper.tldr || ''),
    tags: (paper.tags || []).slice(0, 6),
    links: Object.entries(paper.links || {})
      .filter(([, value]) => value)
      .map(([key, value]) => ({ href: value, label: linkLabel(key) })),
    analysisUrl: localizePath(`/papers/${paper.id}`, lang),
    analysisLabel: _t('paperCard.analysis'),
  };
});
const paperIndexJson = JSON.stringify(paperIndex).replace(/</g, '\\u003c');
---
<div
  class="card-grid papers-grid"
  data-progressive-grid
  data-initial-visible={INITIAL_VISIBLE_COUNT}
  data-batch-size={BATCH_SIZE}
  data-empty-label={_t('paperList.empty')}
>
  {initialPapers.map((paper) => <PaperCard paper={paper} lang={lang} />)}
</div>
<div class="paper-list-actions">
  <button id="loadMorePapers" class="load-more-button" type="button">{_t('paperList.loadMore')}</button>
</div>
<script id="paperIndexData" type="application/json" set:html={paperIndexJson}></script>

<script is:inline>
  (() => {
    const grid = document.querySelector('[data-progressive-grid]');
    const dataEl = document.getElementById('paperIndexData');
    const loadMoreButton = document.getElementById('loadMorePapers');
    if (!grid || !dataEl) return;

    let papers = [];
    try {
      papers = JSON.parse(dataEl.textContent || '[]');
    } catch {
      return;
    }

    const initialVisible = Number(grid.dataset.initialVisible) || 48;
    const batchSize = Number(grid.dataset.batchSize) || 48;
    const emptyLabel = grid.dataset.emptyLabel || 'No papers match current filters.';
    const loadMoreLabel = loadMoreButton?.textContent?.trim() || 'Show more papers';
    let visibleLimit = initialVisible;
    let filters = { query: '', category: '', year: '', sort: 'score' };

    function normalize(value) {
      return String(value || '').trim().toLowerCase();
    }

    function matchesFilters(paper) {
      const query = normalize(filters.query);
      const category = normalize(filters.category);
      const year = normalize(filters.year);
      const categories = normalize(paper.category).split('|').filter(Boolean);
      return (!query || normalize(paper.searchText).includes(query))
        && (!category || categories.includes(category))
        && (!year || normalize(paper.year) === year);
    }

    function scoreValue(paper) {
      const value = Number(paper.score || 0);
      return Number.isFinite(value) ? value : 0;
    }

    function yearValue(paper) {
      const value = Number(paper.year || 0);
      return Number.isFinite(value) ? value : 0;
    }

    function alphaValue(paper) {
      return normalize(paper.displayTitle || paper.title);
    }

    function sortPapers(list) {
      const mode = normalize(filters.sort || 'score');
      return [...list].sort((a, b) => {
        if (mode === 'alpha') {
          return alphaValue(a).localeCompare(alphaValue(b)) || scoreValue(b) - scoreValue(a) || Number(a.index || 0) - Number(b.index || 0);
        }
        if (mode === 'year') {
          return yearValue(b) - yearValue(a) || scoreValue(b) - scoreValue(a) || alphaValue(a).localeCompare(alphaValue(b));
        }
        return scoreValue(b) - scoreValue(a) || yearValue(b) - yearValue(a) || alphaValue(a).localeCompare(alphaValue(b));
      });
    }

    function textEl(tag, className, text) {
      const el = document.createElement(tag);
      if (className) el.className = className;
      el.textContent = text;
      return el;
    }

    function createPaperCard(paper) {
      const article = document.createElement('article');
      article.className = 'paper-card filter-item';
      article.dataset.search = paper.searchText || '';
      article.dataset.category = paper.category || '';
      article.dataset.year = paper.year || '';
      article.dataset.title = paper.displayTitle || paper.title || '';
      article.dataset.score = String(paper.score || 0);

      const preview = document.createElement('a');
      preview.className = 'preview-wrap';
      preview.href = paper.detailUrl;
      const img = document.createElement('img');
      img.src = paper.preview || '{{BASE_PATH}}/assets/placeholder.svg';
      img.alt = `Preview for ${paper.title}`;
      img.loading = 'lazy';
      preview.append(img);
      article.append(preview);

      const body = document.createElement('div');
      body.className = 'paper-body';

      const meta = document.createElement('div');
      meta.className = 'paper-meta';
      meta.append(textEl('span', '', paper.venueYear || ''));
      if (paper.score != null && paper.scoreLevel) {
        meta.append(textEl('span', `score-badge score-${paper.scoreLevel}`, String(paper.score)));
      }
      meta.append(textEl('span', '', paper.typeLabel || 'method'));
      body.append(meta);

      const title = document.createElement('h3');
      const titleLink = document.createElement('a');
      titleLink.href = paper.detailUrl;
      titleLink.textContent = paper.displayTitle || paper.title || '';
      title.append(titleLink);
      body.append(title);

      if (paper.tldr) {
        body.append(textEl('p', 'paper-tldr', paper.tldr));
      }

      const tagRow = document.createElement('div');
      tagRow.className = 'tag-row';
      for (const tag of paper.tags || []) {
        tagRow.append(textEl('span', 'tag', tag));
      }
      body.append(tagRow);

      const linkRow = document.createElement('div');
      linkRow.className = 'link-row';
      for (const link of paper.links || []) {
        const anchor = document.createElement('a');
        anchor.href = link.href;
        anchor.target = '_blank';
        anchor.rel = 'noreferrer';
        anchor.textContent = link.label;
        linkRow.append(anchor);
      }
      const analysis = document.createElement('a');
      analysis.href = paper.analysisUrl || paper.detailUrl;
      analysis.className = 'interpret-link';
      analysis.textContent = paper.analysisLabel || 'Analysis';
      linkRow.append(analysis);
      body.append(linkRow);

      article.append(body);
      return article;
    }

    function updateResultCount(visible, total) {
      window.dispatchEvent(new CustomEvent('hub-filter-count', {
        detail: { visible, total, all: papers.length },
      }));
    }

    function render() {
      const filtered = sortPapers(papers.filter(matchesFilters));
      const visible = filtered.slice(0, visibleLimit);
      const fragment = document.createDocumentFragment();

      if (visible.length === 0) {
        const empty = textEl('p', 'empty-state', emptyLabel);
        fragment.append(empty);
      } else {
        for (const paper of visible) {
          fragment.append(createPaperCard(paper));
        }
      }

      grid.replaceChildren(fragment);

      if (loadMoreButton) {
        const remaining = Math.max(filtered.length - visible.length, 0);
        loadMoreButton.hidden = remaining === 0;
        loadMoreButton.textContent = remaining > 0
          ? `${loadMoreLabel} (${Math.min(batchSize, remaining)})`
          : loadMoreLabel;
      }
      updateResultCount(visible.length, filtered.length);
    }

    window.addEventListener('hub-filter-change', (event) => {
      filters = event.detail || { query: '', category: '', year: '', sort: 'score' };
      visibleLimit = initialVisible;
      render();
    });

    loadMoreButton?.addEventListener('click', () => {
      visibleLimit += batchSize;
      render();
    });

    render();
  })();
</script>
